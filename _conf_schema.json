      "block_keywords_initialized": {
        "type": "bool",
        "description": "唤醒屏蔽词已初始化",
        "default": false,
        "invisible": true
      },
      "command_block_enabled": {
        "type": "bool",
        "description": "启用指令屏蔽",
        "default": true
      },
      "builtin_commands": {
        "type": "list",
        "description": "内置指令列表",
        "default": [
          "llm",
          "t2i",
          "tts",
          "sid",
          "op",
          "wl",
          "dashboard_update",
          "alter_cmd",
          "provider",
          "model",
          "plugin",
          "plugin ls",
          "new",
          "switch",
          "rename",
          "del",
          "reset",
          "history",
          "persona",
          "tool ls",
          "key",
          "websearch"
        ]
      },
      "block_builtin_commands": {
        "type": "bool",
        "description": "禁止内置指令触发",
        "default": false,
        "hint": "开启后，命中 builtin_commands 的消息会被停止传播。"
      },
      "block_prefix_commands": {
        "type": "bool",
        "description": "屏蔽唤醒词缀命令消息",
        "default": false,
        "hint": "开启后，像「当前 AstrBot 唤醒词缀 + qq_avatar」这类命中指令的消息，会被本模块直接拦截：不执行后续指令，也不交给 LLM。唤醒词缀不固定是 /。"
      },
      "block_prefix_llm": {
        "type": "bool",
        "description": "屏蔽唤醒词缀普通消息",
        "default": false,
        "hint": "开启后，像「当前 AstrBot 唤醒词缀 + 帮我写个文案」这种没有命中任何指令的普通消息，不会交给 LLM；真正的指令不受这个开关影响。"
      },
      "debounce_enabled": {
        "type": "bool",
        "description": "启用消息防抖",
        "default": true
      },
      "debounce_listen_seconds": {
        "type": "float",
        "description": "防抖监听时长秒数",
        "default": 3.0,
        "min": 0,
        "max": 60,
        "hint": "bot 被唤醒后，同一用户在窗口内连续发言会尝试合并到上一轮请求。设为 0 表示关闭。"
      },
      "debounce_max_merge_count": {
        "type": "int",
        "description": "最多合并消息数",
        "default": 3,
        "min": 0,
        "max": 50,
        "hint": "设为 0 表示不限制。达到上限后不再继续监听下一条。"
      },
      "debounce_message_types": {
        "type": "list",
        "description": "参与防抖的消息类型",
        "options": [
          "normal",
          "at",
          "reply",
          "command"
        ],
        "default": [
          "normal",
          "at",
          "reply"
        ],
        "hint": "normal: 普通消息；at: @bot；reply: 引用 bot；command: 指令。"
      },
      "at_wake_enabled": {
        "type": "bool",
        "description": "允许 @ bot 唤醒",
        "default": true
      },
      "disable_reply_wake": {
        "type": "bool",
        "description": "禁用纯引用唤醒",
        "default": true,
        "hint": "引用 bot 消息时不会唤醒 LLM，除非同一条消息里同时 @ bot 或命中唤醒词。"
      },
      "wake_words": {
        "type": "list",
        "description": "通用唤醒词",
        "default": []
      },
      "admin_wake_words": {
        "type": "list",
        "description": "管理员专属唤醒词",
        "default": [
          "宝贝",
          "宝宝"
        ]
      },
      "trigger_modes": {
        "type": "list",
        "description": "唤醒词触发方式",
        "options": [
          "自由触发",
          "前缀触发",
          "后缀触发"
        ],
        "default": [
          "自由触发"
        ],
        "hint": "自由触发：消息包含唤醒词即可；前缀触发：消息以唤醒词开头；后缀触发：消息以唤醒词结尾。可多选。"
      },
      "strip_prefix_suffix_wake_word": {
        "type": "bool",
        "description": "前缀/后缀触发后移除唤醒词",
        "default": false,
        "hint": "只对前缀触发和后缀触发生效；自由触发不会改写消息文本。"
      }
    }
  },
  "wallpaper": {
    "type": "object",
    "description": "本地随机壁纸",
    "items": {
      "enabled": {
        "type": "bool",
        "description": "启用本地随机壁纸模块",
        "default": true
      },
      "commands_enabled": {
        "type": "bool",
        "description": "启用壁纸库随机发送指令",
        "default": true
      },
      "add_enabled": {
        "type": "bool",
        "description": "启用存图功能",
        "default": true
      },
      "delete_enabled": {
        "type": "bool",
        "description": "启用删图功能",
        "default": true
      },
      "mutate_admin_only": {
        "type": "bool",
        "description": "只有管理员可以存图/删图",
        "default": true
      },
      "add_commands": {
        "type": "list",
        "description": "存图指令",
        "default": [
          "存图"
        ],
        "hint": "可直接用「存图 图库名」，也可使用「当前 AstrBot 唤醒词缀 + 存图 图库名」。旧配置里带 / 的写法也会兼容。"
      },
      "delete_commands": {
        "type": "list",
        "description": "删图指令",
        "default": [
          "删图"
        ],
        "hint": "可直接用「删图」，也可使用「当前 AstrBot 唤醒词缀 + 删图」。旧配置里带 / 的写法也会兼容。"
      },
      "allowed_extensions": {
        "type": "list",
        "description": "允许的图片扩展名",
        "default": [
          ".jpg",
          ".jpeg",
          ".png",
          ".webp",
          ".gif"
        ]
      },
      "max_add_bytes": {
        "type": "int",
        "description": "单张图片最大保存字节数",
        "default": 20971520,
        "min": 65536,
        "max": 209715200
      },
      "deduplicate_on_add": {
        "type": "bool",
        "description": "存图时按 SHA256 去重",
        "default": true
      },
      "stop_event_after_response": {
        "type": "bool",
        "description": "壁纸命令响应后阻止后续处理",
        "default": true
      },
      "libraries": {
        "type": "template_list",
        "description": "壁纸库列表",
        "templates": {
          "library": {
            "name": "壁纸库",
            "items": {
              "name": {
                "type": "string",
                "description": "壁纸库名称",
                "default": "卡比壁纸"
              },
              "path": {
                "type": "string",
                "description": "本地图片目录",
                "default": "",
                "hint": "留空时使用插件数据目录下的 wallpapers/<库名>。相对路径也会按插件数据目录解析。"
              },
              "commands": {
                "type": "list",
                "description": "随机抽图指令",
                "default": [
                  "卡比壁纸"
                ],
                "hint": "填写命令名即可，例如「卡比壁纸」。发送时使用当前 AstrBot 唤醒词缀触发，例如全局唤醒词缀是 / 时发送 /卡比壁纸，是 ! 时发送 !卡比壁纸。旧配置里带 / 的写法也会兼容。"
              },
              "caption": {
                "type": "string",
                "description": "发送图片时附带的文案",
                "default": "随机给你摸一张 {library}。",
                "hint": "可用占位符：{library}、{filename}、{path}"
              },
              "send_mode": {
                "type": "string",
                "description": "文案发送方式",
                "options": [
                  "同一条消息",
                  "先发文案再发图",
                  "只发图片"
                ],
                "default": "同一条消息"
              },
              "recursive": {
                "type": "bool",
                "description": "递归扫描子目录",
                "default": false
              }
            }
          }
        },
        "default": [
          {
            "__template_key": "library",
            "name": "卡比壁纸",
            "path": "",
            "commands": [
              "卡比壁纸"
            ],
            "caption": "随机给你摸一张 {library}。",
            "send_mode": "同一条消息",
            "recursive": false
          }
        ]
      },
      "auto_create_library_on_add": {
        "type": "bool",
        "description": "存图到不存在的图库时自动新建",
        "default": true,
        "hint": "开启后，带图发送「存图 新图库名」会自动创建图库目录，并把图库条目写入配置。没带图时不会创建。"
      }
    }
  },
  "qq_avatar": {
    "type": "object",
    "description": "QQ 头像工具",
    "items": {
      "enabled": {
        "type": "bool",
        "description": "启用 QQ 头像模块",
        "default": true
      },
      "llm_tool_enabled": {
        "type": "bool",
        "description": "注册 get_qq_avatar LLM 工具",
        "default": true
      },
      "commands_enabled": {
        "type": "bool",
        "description": "启用 qq_avatar 命令",
        "default": true,
        "hint": "实际触发方式由 AstrBot 全局唤醒词缀决定，例如 /qq_avatar 或 !qq_avatar。"
      },
      "download_image_for_llm": {
        "type": "bool",
        "description": "工具调用时下载头像并把图片内容返回给模型",
        "default": true,
        "hint": "关闭后只返回头像 URL。下载失败时会自动降级为 URL。"
      },
      "default_size": {
        "type": "string",
        "description": "默认头像尺寸",
        "default": "640",
        "options": [
          "40",
          "100",
          "140",
          "640"
        ]
      },
      "download_timeout_seconds": {
        "type": "int",
        "description": "头像下载超时秒数",
        "default": 8,
        "min": 1,
        "max": 60
      },
      "max_download_bytes": {
        "type": "int",
        "description": "头像最大下载字节数",
        "default": 2097152,
        "min": 65536,
        "max": 10485760
      },
      "auto_change": {
        "type": "object",
        "description": "自动更换 bot QQ 头像",
        "items": {
          "enabled": {
            "type": "bool",
            "description": "启用自动随机更换 bot QQ 头像",
            "default": false,
            "hint": "开启后会按下面的 cron 时间表，从头像池目录随机选择一张图片并调用 OneBot 的 set_qq_avatar。"
          },
          "image_dir": {
            "type": "string",
            "description": "头像池目录",
            "default": "",
            "hint": "留空时使用插件数据目录下的 avatar_pool。也可以填绝对路径，或相对插件数据目录的路径。"
          },
          "recursive": {
            "type": "bool",
            "description": "递归扫描子目录",
            "default": false,
            "hint": "开启后头像池目录下面的子文件夹也会一起参与随机抽取。"
          },
          "cron_expression": {
            "type": "string",
            "description": "更换时间表",
            "default": "0 8 * * *",
            "hint": "必须是 5 段 cron：分 时 日 月 周。例如每天 8 点是 0 8 * * *，每 6 小时是 0 */6 * * *。如果只填 4 段，插件会自动在最后补 *。"
          },
          "timezone": {
            "type": "string",
            "description": "时间表时区",
            "default": "Asia/Shanghai",
            "hint": "国内通常保持 Asia/Shanghai 即可。"
          },
          "run_on_start": {
            "type": "bool",
            "description": "插件启动时立刻换一次",
            "default": false,
            "hint": "适合测试，日常使用建议关闭，避免每次重载插件都换头像。"
